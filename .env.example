# Database Configuration
DB_HOST=mysql
DB_USER=qpr_user
DB_PASSWORD=change_this_secure_password_in_production
DB_NAME=question_paper_repo
DB_PORT=3306

# Server Configuration
PORT=3000
APP_PORT=3000
NODE_ENV=production

# Protocol Configuration (http or https)
# Change to https when you enable SSL
PROTOCOL=http
DOMAIN=yourdomain.com

# HTTP/HTTPS Ports (for nginx)
HTTP_PORT=80
HTTPS_PORT=443

# JWT Secret (IMPORTANT: Generate a strong secret)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=a8f5f167f44f4964e6c998dee827110c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c8e9c

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads/papers

# Security Configuration
# For production, set specific origins (comma-separated)
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# Session Configuration
SESSION_TIMEOUT=1800000
